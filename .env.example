# =============================================================================
# AgentID-Chain v2.0.1 — 环境变量模板
# =============================================================================
# 用法：
#   cp .env.example .env       # 复制并填入本地值
#   不要把 .env 提交到 git（已被 .gitignore 忽略）
#
# 文档基线：docs/AgentID-Chain-技术文档-v2.0.1.md §11.1
# v2.0.1 收敛：所有变量统一 AGENTID_ 前缀，删除 SQLite 相关变量
#
# ⚠️ 安全提醒：
#   - 示例值仅用于本地开发，**不可用于生产**
#   - 私钥、API Key 必须使用 KMS / Vault 等托管，不要明文配置
#   - 生产环境请通过 K8s Secret / Docker Secret 注入
# =============================================================================

# -----------------------------------------------------------------------------
# 通用 / 运行模式
# -----------------------------------------------------------------------------

# 日志级别: debug | info | warn | error
AGENTID_LOG_LEVEL=info

# 后端模式: onchain | local | hybrid
# - onchain : 仅链上后端（需要链节点 + 合约）
# - local   : 仅本地 PostgreSQL（企业内网零链依赖）
# - hybrid  : 身份链上 + 权限本地（兼顾安全与性能）
AGENTID_BACKEND_TYPE=local

# 服务端点（CLI/MCP 客户端使用，指向 gateway）
AGENTID_ENDPOINT=http://localhost:8080

# -----------------------------------------------------------------------------
# 数据库（本地 / 混合模式必填）
# -----------------------------------------------------------------------------

# PostgreSQL DSN（v2.0.1 强制 postgres，不再支持 sqlite）
# 形如: postgres://<user>:<pass>@<host>:<port>/<db>?sslmode=<mode>
AGENTID_DB_DSN=postgres://agentid:agentid_dev@localhost:5432/agentid?sslmode=disable

# -----------------------------------------------------------------------------
# Redis（所有模式必填）
# -----------------------------------------------------------------------------

# Redis 地址（缓存、Nonce 防重放、A2A Token 撤销列表）
AGENTID_REDIS_ADDR=localhost:6379

# Redis 密码（开发环境可留空）
AGENTID_REDIS_PASSWORD=

# Redis DB 编号
AGENTID_REDIS_DB=0

# -----------------------------------------------------------------------------
# API 鉴权
# -----------------------------------------------------------------------------

# 入站 API 调用密钥（客户端 → gateway）
# 生产环境强烈建议改用 OIDC / mTLS / A2A Token，弃用静态 API Key
AGENTID_API_KEY=devkey-replace-me

# -----------------------------------------------------------------------------
# 链上后端（onchain / hybrid 模式必填）
# -----------------------------------------------------------------------------

# 链驱动: fisco | polygon | bsc | mock
AGENTID_CHAIN_DRIVER=mock

# 链 RPC URL
AGENTID_CHAIN_RPC_URL=http://localhost:8545

# 链上操作私钥（v2.0.1 重命名，原为 PRIVATE_KEY）
# ⚠️ 示例值为 Anvil/Hardhat 公知测试私钥，仅本地可用
AGENTID_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# -----------------------------------------------------------------------------
# AAP 协议（Agent Admission Protocol）
# -----------------------------------------------------------------------------

# AAP 域签名私钥（Ed25519，base64 编码）
# 生成示例: openssl genpkey -algorithm ED25519 -out aap_ed25519.pem
#          openssl pkey -in aap_ed25519.pem -outform DER | base64
# ⚠️ 生产必填；示例值占位，不可使用
AGENTID_DOMAIN_PRIVATE_KEY=MC4CAQAwBQYDK2VwBCIEIEXAMPLE_DO_NOT_USE_IN_PROD_REPLACE_ME_BASE64==

# -----------------------------------------------------------------------------
# A2A 协议（Agent-to-Agent Token）
# -----------------------------------------------------------------------------

# A2A Token 签名私钥（Ed25519，base64 编码）
# ⚠️ 生产必填；示例值占位，不可使用
AGENTID_A2A_PRIVATE_KEY=MC4CAQAwBQYDK2VwBCIEIEXAMPLE_DO_NOT_USE_IN_PROD_REPLACE_ME_BASE64==

# A2A Token 签名 Key ID（写入 JWT header.kid，用于公钥轮换）
AGENTID_A2A_KEY_ID=agentid-gateway-2026

# -----------------------------------------------------------------------------
# 观测
# -----------------------------------------------------------------------------

# OpenTelemetry OTLP 端点（空 = 不启用）
AGENTID_OTEL_ENDPOINT=

# Prometheus metrics 端口（与 CLAUDE.md 尾号规则一致）
AGENTID_METRICS_ADDR=:9090

# -----------------------------------------------------------------------------
# 已删除（v2.0.1 历史变量，保留备查）
# -----------------------------------------------------------------------------

# AGENTID_ENCRYPTION_KEY  — v2.0.1 删除（统一 PostgreSQL，不再需要 SQLite 文件加密）
# PRIVATE_KEY             — v2.0.1 重命名为 AGENTID_PRIVATE_KEY
