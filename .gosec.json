{
  "$schema": "https://github.com/securego/gosec/raw/master/cmd/gosec/jsonschema/gjsonschema.json",
  "global": {
    "nosec": false,
    "audit": false
  },
  "rules": {
    "G101": {
      "name": "Hardcoded credentials",
      "severity": "HIGH",
      "confidence": "HIGH",
      "description": "Look for hardcoded credentials",
      "match": "(?i)(password|passwd|secret|api[_-]?key|access[_-]?token|auth[_-]?token)\\s*[:=]\\s*[\"'][^\"']{8,}[\"']"
    },
    "G102": {
      "severity": "MEDIUM",
      "confidence": "MEDIUM"
    },
