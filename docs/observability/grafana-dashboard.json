{
  "title": "AgentID-Chain / Overview",
  "uid": "agentid-chain-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": ["agentid-chain", "production"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_requests_total, service_name)",
        "refresh": 2
      },
      {
        "name": "route",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_request_duration_seconds_bucket{service_name=\"$service\"}, route)",
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP 延迟 P50 / P95 / P99",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service_name=\"$service\",route=~\"$route\"}[5m])) by (le, route))",
          "legendFormat": "P50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service_name=\"$service\",route=~\"$route\"}[5m])) by (le, route))",
          "legendFormat": "P95 {{route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service_name=\"$service\",route=~\"$route\"}[5m])) by (le, route))",
          "legendFormat": "P99 {{route}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.5}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP 吞吐量 (RPS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service_name=\"$service\",route=~\"$route\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 3,
      "title": "错误率 (5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service_name=\"$service\",status_code=~\"5..\"}[5m])) by (route) / sum(rate(http_requests_total{service_name=\"$service\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.001},
              {"color": "red", "value": 0.005}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "AAP 验证成功率",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(aap_verify_total{result=\"success\"}[5m])) / sum(rate(aap_verify_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.95},
              {"color": "green", "value": 0.99}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "活跃 AAP 会话",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"x": 18, "y": 8, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "aap_active_sessions",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "后端延迟 P99 (PG / Redis)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(backend_request_duration_seconds_bucket{type=\"postgres\"}[5m])) by (le, op))",
          "legendFormat": "PG/{{op}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(backend_request_duration_seconds_bucket{type=\"redis\"}[5m])) by (le, op))",
          "legendFormat": "Redis/{{op}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 7,
      "title": "缓存命中率",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(cache_operations_total{result=\"hit\"}[5m])) by (backend) / sum(rate(cache_operations_total{result=~\"hit|miss\"}[5m])) by (backend)",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 8,
      "title": "A2A Token 颁发 / 撤销",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(a2a_token_issued_total[5m]))",
          "legendFormat": "Issued",
          "refId": "A"
        },
        {
          "expr": "sum(rate(a2a_token_revoked_total[5m]))",
          "legendFormat": "Revoked",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Goroutine / Heap",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "go_goroutines{service_name=\"$service\"}",
          "legendFormat": "Goroutines",
          "refId": "A"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes{service_name=\"$service\"} / 1024 / 1024",
          "legendFormat": "Heap (MB)",
          "refId": "B"
        }
      ]
    }
  ]
}
