{
  "name": "batch_register",
  "description": "批量注册多个 Agent",
  "version": "2.0.1",
  "input_schema": {
    "type": "object",
    "properties": {
      "agents": {
        "type": "array",
        "minItems": 1,
        "maxItems": 1000,
        "items": {
          "type": "object",
          "properties": {
            "owner": {"type": "string"},
            "level": {"type": "string", "enum": ["test", "prod", "internal"]},
            "metadata": {"type": "object"}
          },
          "required": ["owner", "level"]
        }
      }
    },
    "required": ["agents"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "results": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "agent_id": {"type": "string"},
            "owner": {"type": "string"},
            "level": {"type": "string"},
            "status": {"type": "string"},
            "error": {"type": "string", "nullable": true}
          }
        }
      },
      "success_count": {"type": "integer"},
      "failure_count": {"type": "integer"}
    },
    "required": ["results", "success_count", "failure_count"]
  },
  "mcp_tool": {"name": "batch_register", "method": "tools/call"}
}
