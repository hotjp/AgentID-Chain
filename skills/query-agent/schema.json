{
  "name": "get_agent",
  "description": "查询 Agent 详情",
  "version": "2.0.1",
  "input_schema": {
    "type": "object",
    "properties": {
      "uuid": {
        "type": "string",
        "format": "uuid",
        "description": "Agent UUID"
      }
    },
    "required": ["uuid"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "agent_id": {"type": "string", "format": "uuid"},
      "owner": {"type": "string"},
      "level": {"type": "string"},
      "status": {"type": "string"},
      "created_at": {"type": "string", "format": "date-time"},
      "metadata": {"type": "object"},
      "chain_tx_hash": {"type": "string", "nullable": true}
    },
    "required": ["agent_id", "owner", "level", "status", "created_at"]
  },
  "mcp_tool": {"name": "get_agent", "method": "tools/call"}
}
