{
  "name": "upgrade_agent",
  "description": "升级 Agent 等级",
  "version": "2.0.1",
  "input_schema": {
    "type": "object",
    "properties": {
      "uuid": {"type": "string", "format": "uuid"},
      "new_level": {"type": "string", "enum": ["test", "prod", "internal"]}
    },
    "required": ["uuid", "new_level"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "agent_id": {"type": "string", "format": "uuid"},
      "owner": {"type": "string"},
      "level": {"type": "string"},
      "status": {"type": "string"},
      "created_at": {"type": "string", "format": "date-time"}
    },
    "required": ["agent_id", "owner", "level", "status", "created_at"]
  },
  "mcp_tool": {"name": "upgrade_agent", "method": "tools/call"}
}
